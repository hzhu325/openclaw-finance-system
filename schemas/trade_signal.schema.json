{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradeSignal",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "symbol",
    "horizon",
    "recommendation",
    "confidence",
    "rationale",
    "indicators",
    "order",
    "risk",
    "human_approval_required"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "symbol": { "type": "string" },
    "horizon": { "type": "string" },
    "recommendation": { "enum": ["BUY", "SELL", "HOLD"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rationale": { "type": "array", "items": { "type": "string" } },
    "indicators": { "type": "object" },
    "order": {
      "type": "object",
      "required": ["action", "quantity", "order_type"],
      "properties": {
        "action": { "enum": ["BUY", "SELL", "HOLD"] },
        "quantity": { "type": "integer", "minimum": 0 },
        "order_type": { "enum": ["MARKET", "LIMIT", "NONE"] },
        "limit_price": { "type": ["number", "null"] },
        "stop_loss": { "type": ["number", "null"] },
        "take_profit": { "type": ["number", "null"] },
        "time_in_force": { "type": "string" }
      }
    },
    "risk": {
      "type": "object",
      "required": ["max_position_pct", "max_loss_pct"],
      "properties": {
        "max_position_pct": { "type": "number" },
        "max_loss_pct": { "type": "number" }
      }
    },
    "human_approval_required": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "recommendation": { "enum": ["BUY", "SELL"] }
        }
      },
      "then": {
        "properties": {
          "human_approval_required": { "const": true }
        }
      }
    }
  ]
}
